{
  "expo": {
    "name": "QINETIC",
    "slug": "QINETIC",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/QINETIC_App_Icon.png",
    "splash": {
      "image": "./assets/images/QINETIC_SpplashScreen_Icon.png",
      "backgroundColor": "#FFD944",
      "resizeMode": "contain"
    },
    "scheme": "taa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ivanjr.TAA",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow QINETIC to access your photos to set a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/QINETIC_SpplashScreen_Icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FCCD16"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.778760395898-u4nm3pf3ujfbrldccp61q11php2vrp28"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow QINETIC to access your photos to set a profile picture."
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bbf6f49d-7499-44e5-871a-d57bd6f7d1c6"
      }
    }
  }
}
